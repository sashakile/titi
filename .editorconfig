root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{clj,cljs,cljc,cljr,edn}]
indent_style = space
indent_size = 2

[*.{csproj,props,targets,sln,slnx}]
indent_style = space
indent_size = 2

[*.{cs,fs}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
